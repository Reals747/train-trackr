  "ADMIN": {
    "label": "Admin",
    "description": "Invited manager. Everything except store rename/delete and touching the owner.",
    "permissions": [
      "settings.account",
      "settings.appearance",
      "settings.store.view",
      "settings.trainingSetup",
      "settings.trainers",
      "members.view",
      "members.invite",
      "members.updateRole",
      "members.remove",
      "announcements.post",
      "announcements.delete",
      "announcements.comment",
      "trainees.create",
      "trainees.update",
      "trainees.delete",
      "workflow.edit",
      "activity.view",
      "positions.manage",
      "checklistItems.manage"
    ]
  },
  "TRAINER": {
    "label": "Trainer",
    "description": "Shift trainer. Train, comment, add trainees.",
    "permissions": [
      "settings.account",
      "settings.appearance",
      "announcements.comment",
      "trainees.create",
      "trainees.update",
      "workflow.edit"
