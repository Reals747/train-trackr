      "settings.appearance",
      "settings.store.view",
      "settings.store.rename",
      "settings.store.delete",
      "settings.trainingSetup",
      "settings.trainers",
      "members.view",
      "members.invite",
      "members.updateRole",
      "members.remove",
      "announcements.post",
      "announcements.delete",
      "announcements.comment",
      "trainees.create",
      "trainees.update",
      "trainees.delete",
      "workflow.edit",
      "activity.view",
      "positions.manage",
      "checklistItems.manage"
