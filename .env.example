# Copy to `.env.local` for local development. Never commit real secrets.

# --- HotSchedules (Fourth) SOAP API ---
# Set to true once credentials are ready. When false, the Schedule tab uses mock data.
HOTSCHEDULES_ENABLED=

# API username/password from your HotSchedules account manager
HOTSCHEDULES_USERNAME=
HOTSCHEDULES_PASSWORD=

# Integer IDs from HotSchedules (see docs/integrations/hotschedules/ARCHITECTURE.md)
HOTSCHEDULES_CONCEPT=
HOTSCHEDULES_STORE_NUM=
