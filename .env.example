# Copy to `.env.local` for local development. Never commit real secrets.

# --- Fourth Schedules API (HotSchedules / Workforce Management) ---
# Guide: https://developer.fourth.com/en-gb/docs/schedules-api/guide
# Set to true once credentials are ready. When false, the Schedule tab uses mock data.
FOURTH_SCHEDULES_ENABLED=false

# Root URL for GET /shifts (provided by Fourth Professional Services)
FOURTH_SCHEDULES_API_ROOT_URL=

# Basic auth credentials (Schedules API account from your Fourth account manager)
FOURTH_SCHEDULES_USERNAME=
FOURTH_SCHEDULES_PASSWORD=

# Legacy aliases (optional): HOTSCHEDULES_ENABLED, HOTSCHEDULES_USERNAME, HOTSCHEDULES_PASSWORD
