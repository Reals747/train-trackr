generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  /// Privileged developer account. Full access to every action; cannot be demoted or removed.
  /// Assigned by hand (see prisma/scripts/apply-website-developer-role.ts), never via the UI.
  WEBSITE_DEVELOPER
  OWNER
  ADMIN
  TRAINER
  VIEWER
}

model Store {
  id               String          @id @default(cuid())
  name             String
  /** Permanent, unique 8-digit join code shown in Settings; shared with trainers so they can sign in. */
  storeCode        String          @unique
  createdAt        DateTime        @default(now())
  users            User[]
  positions        Position[]
  trainees         Trainee[]
  activityLogs     ActivityLog[]
  settings         StoreSetting?
  announcements    Announcement[]
  taskRows         TaskRow[]
  taskPresets      TaskPreset[]
  taskWeekArchives TaskWeekArchive[]
}

model User {
  id                      String               @id @default(cuid())
  name                    String
  /** Login identifier for owners/admins/trainers. Unique per store, so different stores can share usernames. */
  username                String
  /** Null for trainers (no password flow); required for owners/admins. */
  passwordHash            String?
  role                    Role
  storeId                 String
  /** Legacy: kept for telemetry only; new trainers don't use single-use invite codes. */
  trainerInviteCodeUsed   String?
  /** Per-user UI prefs (accent, dark mode, etc.) — synced across devices for this account. */
  appearanceJson        Json?
  createdAt               DateTime             @default(now())
  store                   Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  completions             TrainingProgress[]
  activityLogs            ActivityLog[]
  announcementsAuthored   Announcement[]       @relation("AnnouncementAuthor")
  announcementComments    AnnouncementComment[]

  @@unique([storeId, username])
}

model Announcement {
  id        String                @id @default(cuid())
  storeId   String
  title     String
  body      String
  authorId  String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  store     Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  author    User                  @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments  AnnouncementComment[]

  @@index([storeId, createdAt])
}

model AnnouncementComment {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  body           String
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([announcementId, createdAt])
}

model StoreSetting {
  id                    String    @id @default(cuid())
  storeId               String    @unique
  trainerCanViewAll     Boolean   @default(true)
  darkModeEnabled       Boolean   @default(false)
  store                 Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Position {
  id              String                      @id @default(cuid())
  storeId         String
  name            String
  hidden          Boolean                     @default(false)
  /** Manual sort order within a store; 0-based ascending. Backfilled from alphabetical name on first migration. */
  order           Int                         @default(0)
  createdAt       DateTime                    @default(now())
  store           Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items           ChecklistItem[]
  trainees        TraineePosition[]
  workflowComments WorkflowGeneralComments[]

  @@unique([storeId, name])
  @@index([storeId, order])
}

model ChecklistItem {
  id          String             @id @default(cuid())
  positionId  String
  text        String
  description String?
  order       Int                @default(0)
  /** "item" = trackable checklist row; "header" = non-clickable section divider that does not count toward completion. */
  kind        String             @default("item")
  createdAt   DateTime           @default(now())
  position    Position           @relation(fields: [positionId], references: [id], onDelete: Cascade)
  progress    TrainingProgress[]
}

model Trainee {
  id               String                    @id @default(cuid())
  storeId          String
  name             String
  startDate        DateTime
  createdAt        DateTime                  @default(now())
  store            Store                     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  positions        TraineePosition[]
  progress         TrainingProgress[]
  workflowComments WorkflowGeneralComments[]

  @@index([storeId, name])
}

/** Free-form workflow notes for a trainee on a given checklist position (not tied to assignment rows). */
model WorkflowGeneralComments {
  traineeId       String
  positionId      String
  generalComments String   @default("")
  updatedAt       DateTime @updatedAt
  trainee         Trainee  @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  position        Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@id([traineeId, positionId])
}

model TraineePosition {
  traineeId   String
  positionId  String
  assignedAt  DateTime @default(now())
  trainee     Trainee  @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@id([traineeId, positionId])
}

model TrainingProgress {
  id              String        @id @default(cuid())
  traineeId       String
  checklistItemId String
  completed       Boolean       @default(false)
  trainerName     String?
  notes           String?
  completedAt     DateTime?
  completedById   String?
  updatedAt       DateTime      @updatedAt
  trainee         Trainee       @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  completedBy     User?         @relation(fields: [completedById], references: [id], onDelete: SetNull)

  @@unique([traineeId, checklistItemId])
  @@index([traineeId, completed])
}

/**
 * One employee row in the store-wide Tasks grid. Managers add/rename/reorder/remove rows.
 * Labels are free-form names (not tied to login accounts). `order` is 0-based ascending.
 */
model TaskRow {
  id        String     @id @default(cuid())
  storeId   String
  label     String     @default("")
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cells     TaskCell[]

  @@index([storeId, order])
}

/**
 * One editable cell of the Tasks grid, owned by a row (employee) and a day column
 * (colIndex 0..5 = Mon..Sat). Sparse: only edited cells are stored. `content` holds one task
 * per line with optional `[x]`/`[ ]` checkbox markers — see `@/lib/tasks`.
 */
model TaskCell {
  id        String   @id @default(cuid())
  rowId     String
  colIndex  Int
  content   String   @default("")
  updatedAt DateTime @updatedAt
  row       TaskRow  @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@unique([rowId, colIndex])
  @@index([rowId])
}

/**
 * A reusable task in the store's "bank". Powers autocomplete while editing cells and the
 * drag-and-drop preset cards. Auto-populated when managers save new task text, and editable
 * directly in the bank UI. `text` is unique per store so the same task isn't banked twice.
 */
model TaskPreset {
  id        String   @id @default(cuid())
  storeId   String
  text      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, text])
  @@index([storeId, order])
}

/**
 * An immutable snapshot of a past week's grid, captured when a manager starts a new week.
 * `data` is the rendered grid (rows, days, tasks, done state) so past weeks can be viewed
 * read-only without depending on the live rows/cells, which keep changing.
 */
model TaskWeekArchive {
  id         String   @id @default(cuid())
  storeId    String
  label      String
  data       Json
  archivedAt DateTime @default(now())
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, archivedAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  storeId   String
  userId    String?
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
}
